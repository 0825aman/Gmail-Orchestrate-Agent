# IBM WatsonX Credentials
# Get your API key from: IBM Cloud → Manage → API Keys
WATSONX_API_KEY=your_watsonx_api_key_here

# Get your Project ID from: WatsonX.ai → Your Project → Manage tab → General → Project ID (GUID)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# WatsonX regional endpoint — us-south region
WATSONX_URL=https://us-south.ml.cloud.ibm.com
